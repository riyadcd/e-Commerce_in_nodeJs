<%- include("../includes/head.ejs") %>
    <link rel="stylesheet" href="/css/product.css">
    
</head>
<body>
    <%- include("../includes/navigation.ejs") %>
    <main>
        <% if(prods.length > 0) { %>
            <p>List of all the products...</p>
        <div class="product-list">
            <% for(let i = 0; i < prods.length; i++) { %>
            <article class="card product-item">
            <header class="card__header">
                <h1 class="product__title"><%= prods[i].title %></h1>
            </header>
            <div class="card__image">
                <img src="/<%= prods[i].imageUrl %>" alt="A Book">
            </div>
            <div class="card__content">
                <h2 class="product__price">$<%= prods[i].price %></h2>
                <p class="product__description"><%= prods[i].description %></p>
            </div>
            <div class="card__actions">
                <a href="/admin/edit-product/<%= prods[i].id%>?edit=true" class="btn">Edit</a>
                <form action="/admin/delete-product" method="post">
                    <input type="hidden" name ="_csrf" value="<%=csrfToken%>">
                    <input type="hidden" name="productId" value="<%=prods[i].id%>">
                    <button type="submit" class="btn">Delete</button>
                </form>
            </div>
            </article>
            <% } %>
        </div>
        <% }else { %>
        <h1>No products</h1>
        <%}%>
    </main>
<%- include("../includes/end.ejs") %>
