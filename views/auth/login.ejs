<%- include("../includes/head.ejs") %>
    <link rel="stylesheet" href="/css/form.css">
    <link rel="stylesheet" href="/css/auth/login.css">
</head>
<body>
    <%- include("../includes/navigation.ejs") %>
    <main>
        <% if(errorMessage  && errorMessage.length > 0){ %>
            <div class="user-message user-message-error"><%= errorMessage %></div>
        <% } %>    
        <form class="login_form" action="/login" method="post">
            <input type="hidden" name ="_csrf" value="<%=csrfToken%>">
            <div class="form-control">
                <label for="email">Email</label>
                <input type="email" class="<%= (validationErrors || []).find(function(e){ return e.path === 'email'; }) ? 'invalid' : '' %>" name="email" id="email" value="<%= oldInput.email %>">
            </div>
            <div class="form-control">
                <label for="password">Password</label>
                <input type="password" class="<%= (validationErrors || []).find(function(e){ return e.path === 'password'; }) ? 'invalid' : '' %>" name="password" id="password" value="<%= oldInput.password %>">
            </div>
            <button type="submit" class="btn">Login</button>
        </form>
        <div class="centered">
            <a href="/reset">Reset Password</a>
        </div>
    </main>
<%- include("../includes/end.ejs") %></body>