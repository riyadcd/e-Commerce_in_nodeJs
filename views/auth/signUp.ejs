<%- include("../includes/head.ejs") %>
    <link rel="stylesheet" href="/css/form.css">
    <link rel="stylesheet" href="/css/auth/login.css">
</head>
<body>
    <%- include("../includes/navigation.ejs") %>
    <main>
        <% if(errorMessage  && errorMessage.length > 0){ %>
            <div class="user-message user-message-error"><%= errorMessage %></div>
        <% } %>   
        <form class="login_form" action="/signUp" method="post">
            <input type="hidden" name ="_csrf" value="<%=csrfToken%>">
            <div class="form-control">
                <label for="userName">Name</label>
                <input type="text" name="userName" id="userName" value="<%= oldInput.userName %>">
            </div>
            <div class="form-control">
                <label for="email">Email</label>
                <input type="email" class="<%= (validationErrors || []).find(function(e){ return e.path === 'email'; }) ? 'invalid' : '' %>" name="email" id="email" value="<%= oldInput.email %>">
            </div>
            <div class="form-control">
                <label for="password">Password</label>
                <input type="password" class="<%= (validationErrors || []).find(function(e){ return e.path === 'password'; }) ? 'invalid' : '' %>" name="password" id="password" value="<%= oldInput.password %>">
            </div>
            <div class="form-control">
                <label for="confirm_password">Confirm Password</label>
                <input type="password" class="<%= (validationErrors || []).find(function(e){ return e.path === 'confirm_password'; }) ? 'invalid' : '' %>" name="confirm_password" id="confirm_password" value="<%= oldInput.confirm_password %>">
            </div>
            <button type="submit" class="btn">Sign Up</button>
        </form>
    </main>
<%- include("../includes/end.ejs") %></body>